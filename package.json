{
  "name": "battle",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node scripts/vercel-dev-local.mjs",
    "dev:full": "node scripts/vercel-dev-local.mjs",
    "dev:local": "node scripts/dev-local.mjs",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "db:start": "npx supabase start",
    "db:stop": "npx supabase stop",
    "db:reset": "npx supabase db reset",
    "seed:complete": "npx supabase db query --local --file scripts/seed-complete-thread.sql",
    "seed:reset": "npx supabase db query --local --file scripts/reset-active-thread.sql",
    "backfill:body-html": "tsx scripts/backfill-body-html.ts",
    "backfill:body-html:production": "tsx scripts/backfill-body-html.ts --production"
  },
  "dependencies": {
    "@google/genai": "^2.11.0",
    "@supabase/supabase-js": "^2.110.4",
    "lucide-react": "^1.24.0",
    "openai": "^6.46.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "oxlint": "^1.71.0",
    "postcss": "^8.5.19",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  },
  "volta": {
    "node": "24.18.0"
  }
}
